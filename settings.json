{
  "env": {
    "JIRA_CLI_SPEC": "C:\\Users\\suryathota\\tools\\jira-cli_SPEC.md.txt",
    "BITBUCKET_CLI_SPEC": "C:\\Users\\suryathota\\tools\\bitbucket-cli_SPEC.md.txt",
    "JIRA_CLI": "C:\\Users\\suryathota\\tools\\jira-cli",
    "BITBUCKET_CLI": "C:\\Users\\suryathota\\tools\\bitbucket-cli"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-prompt.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ng build)",
      "Bash(ng build --*)",
      "Bash(git checkout *)",
      "Bash(git add .)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(cat .claude/*)",
      "Bash(cat C:\\Users\\suryathota\\tools\\*)",
      "Bash(find src/app *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(*bitbucket* delete*)",
      "Bash(*bitbucket* remove*)",
      "Bash(*bitbucket* destroy*)",
      "Bash(*bitbucket* drop*)",
      "Bash(*bitbucket* --force*)",
      "Bash(*bitbucket* force-delete*)",
      "Bash(*bitbucket* force-push*)",
      "Bash(*bitbucket* -D *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)"
    ]
  }
}
