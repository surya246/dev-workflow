{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-prompt.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ng build)",
      "Bash(ng build --*)",
      "Bash(git checkout *)",
      "Bash(git add .)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(cat .claude/jira-context.md)",
      "Bash(ls *)"
    ]
  }
}
